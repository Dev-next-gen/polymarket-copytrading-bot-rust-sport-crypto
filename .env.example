# Copy to .env and fill in your keys. Do not commit .env.
# Agent page: dropdown shows only providers whose API key is set below.
# Use at least one so you can chat with the agent.

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_MAX_TOKENS=1024

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=1024

# Claude.ai / Anthropic (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_MAX_TOKENS=1024
